[
	{
		"name": "main-bar",
		"layer": "top",
		"position": "top",
		"spacing": 8,
		"height": 38,
		"exclusive": true,
		"passthrough": false,
		"reload_style_on_change": true,
		"include": ["~/.config/waybar/includes/modules.jsonc"],
		"modules-left": ["custom/launcher", "niri/workspaces", "niri/window"],
		"modules-center": ["clock", "clock#alt"],
		"modules-right": [
			"custom/screen-recorder",
			"group/pill#music",
			"custom/sysupdate",
			"tray",
			"custom/swaync",
			"group/pill#battery",
			"group/pill#audio",
			"network",
			"niri/language",
		],
		"group/pill#music": {
			"orientation": "inherit",
			"modules": ["mpris", "mpris#alt"],
			"drawer": {
				"transition-left-to-right": true,
				"transition-duration": 300,
			},
		},
		"group/pill#battery": {
			"orientation": "inherit",
			"modules": ["battery", "battery#alt"],
			"drawer": {
				"transition-left-to-right": true,
				"transition-duration": 300,
			},
		},
		"group/pill#audio": {
			"orientation": "inherit",
			"modules": ["pulseaudio", "pulseaudio#alt"],
			"drawer": {
				"transition-left-to-right": true,
				"transition-duration": 300,
			},
		},
		"group/pill#backlight": {
			"orientation": "inherit",
			"modules": ["backlight", "backlight#alt"],
			"drawer": {
				"transition-left-to-right": true,
				"transition-duration": 300,
			},
		},
		"custom/screen-recorder": {
			"hide-empty-text": true,
			"format": "{icon}",
			"tooltip-format": "Screen Recorder: <b>{text}</b>\n<b>Right Click</b>: Record Region",
			"format-icons": {
				"recording": "󰯜",
				"default": "",
			},
		},
		"custom/nightlight": {
			"format": "{icon}",
			"tooltip-format": "Night Light: <b>{icon} {text}</b>",
			"format-icons": {
				"active": "󰽥",
				"default": "󰖨",
			},
		},
		"custom/idle": {
			"format": "{icon}",
			"tooltip-format": "Idle Inhibitor: <b>{icon} {text}</b>",
			"format-icons": {
				"active": "󰈉",
				"default": "󰈈",
			},
		},
		"custom/launcher": {
			"format": "{icon}",
			"tooltip-format": "<big><b>Application Launcher</b></big>\nRight click for more actions",
		},
		"battery": {
			"format": "{icon}",
			"format-icons": {
				"default": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
				"plugged": "",
				"charging": ["󰢟", "󰢜", "󰂆", "󰂇", "󰂈", "󰢝", "󰂉", "󰢞", "󰂊", "󰂋", "󰂅"],
			},
			"tooltip-format": "Battery level: <b>{capacity}%</b>\nPower draw: <b>{power}W</b>\n({timeTo})",
		},
		"battery#alt": {
			"format": "{capacity}%",
			"design-capacity": true,
			"tooltip-format": "Battery level: <b>{capacity}%</b>\nPower draw: <b>{power}W</b>\n({timeTo})",
			"on-scroll-up": "true",
			"on-scroll-down": "true",
		},
		"backlight": {
			"format": "{icon}",
			"format-icons": ["", "", "", "", "", "", "", "", ""],
			"tooltip-format": "{icon} Backlight level: {percent}%",
		},
		"backlight#alt": {
			"format": "{percent}%",
			"tooltip-format": "{icon} Backlight level: {percent}%",
		},
		"pulseaudio": {
			"format": "{icon}",
			"format-muted": "",
			"format-icons": {
				"headphone": "󰋋",
				"headphone-muted": "",
				"hands-free": "󰋋",
				"hands-free-muted": "",
				"headset": "󰋋",
				"headset-muted": "",
				"phone": "",
				"phone-muted": "",
				"portable": "",
				"portable-muted": "",
				"car": "",
				"car-muted": "",
				"default": ["", "", ""],
			},
			"tooltip-format": "{desc}: {volume}%",
		},
		"pulseaudio#alt": {
			"format": "{volume}%",
			"tooltip-format": "{desc}: {volume}%",
		},
		"niri/workspaces": {
			"cursor": false,
			"format": "{index}",
			"format-icons": {
				"default": "",
				// "active": "󰫢",
				"browser": "",
				"chat": "",
			},
		},
		"niri/window": {
			"format": "{title}",
			"max-length": 30,
		},
		"clock": {
			"format": "{:%H:%M}",
			"tooltip-format": "<tt>{calendar}</tt>",
		},
		"clock#alt": {
			"format": "{:%a %d}",
			"tooltip-format": "<tt>{calendar}</tt>",
		},
		"custom/swaync": {
			"format": "{icon}",
			"format-icons": {
				"notification": "󰅸",
				"none": "󰂜",
				"dnd-notification": "󰪑<sup>󰧞</sup>",
				"dnd-none": "󰪑",
				"inhibited-notification": "󰅸",
				"inhibited-none": "󰂜",
				"dnd-inhibited-notification": "󰪑<sup>󰧞</sup>",
				"dnd-inhibited-none": "󰪑",
			},
		},
		"mpris": {
			"format": "{player_icon}",
			"format-paused": "{status_icon}",
			"tooltip-format": "PLAYING [ {position} / {length} ]\n{title} - {artist}",
			"tooltip-format-paused": "PAUSED [ {position} / {length} ]\n{title} - {artist}",
			"player-icons": {
				"default": "󰝚",
			},
			"status-icons": {
				"paused": "󰐊",
			},
		},
		"mpris#alt": {
			"format": "{title}",
			"format-paused": "<i>{title}</i>",
			"tooltip-format": "PLAYING [ {position} / {length} ]\n{title} - {artist}",
			"tooltip-format-paused": "PAUSED [ {position} / {length} ]\n{title} - {artist}",
			"player-icons": {
				"default": "󰝚",
			},
			"status-icons": {
				"paused": "󰐊",
			},
			"max-length": 30,
		},
		"custom/sysupdate": {
			"format": "{icon}",
			"return-type": "json",
			"format-icons": {
				"has-updates": "󱧘",
				"updated": "",
			},
		},
		"tray": {
			"icon-size": 17,
			"spacing": 12,
		},
		"bluetooth": {
			"format": "󰂲",
			"format-disabled": "󰂲",
			"format-off": "󰂲",
			"format-connected": "󰂯",
			"tooltip-format": "{controller_alias}\n{num_connections} connected",
			"tooltip-format-disabled": "{controller_alias}\nBluetooth disabled",
			"tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
			"tooltip-format-enumerate-connected": "{device_alias}",
			"tooltip-format-enumerate-connected-battery": "{device_alias}\t{icon} {device_battery_percentage}%",
		},
		"network": {
			"format": "{icon}",
			"format-icons": {
				"wifi": ["󰤟", "󰤢", "󰤥", "󰤨"],
				"ethernet": "󰈁",
				"linked": "󰈁",
				"disconnected": "󰤮",
			},
			"tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>\nUpload speed: <b>{bandwidthUpBytes}</b>\nDownload speed: <b>{bandwidthDownBytes}</b>",
			"tooltip-format-disconnected": "Disconnected",
		},
		"niri/language": {
			"format": "<span text_transform='uppercase'>{short}</span>",
		},
	},

	/* Borders surrounding the screen + outlines */

	{ "name": "border-right", "layer": "top", "position": "right", "width": 8 },
	{ "name": "border-left", "layer": "top", "position": "left", "width": 8 },
	{ "name": "border-bottom", "layer": "top", "position": "bottom", "height": 8 },
	{ "name": "outline-left", "layer": "top", "position": "left", "width": 2 },
	{ "name": "outline-right", "layer": "top", "position": "right", "width": 2 },
	{ "name": "outline-top", "layer": "top", "position": "top", "height": 2 },
	{ "name": "outline-bottom", "layer": "top", "position": "bottom", "height": 2 },

	/* Desktop widgets */

	{
		"name": "date-widget",
		"layer": "bottom",
		"position": "bottom",
		"exclusive": false,
		// "modules-left": ["mpris#widget"],
		"modules-right": ["clock#widget-date"],
		"clock#widget-date": {
			"format": "{:%A, %d %B %Y}",
			"tooltip": false,
		},
		"mpris#widget": {
			"format": "<b>Playing:</b> {title}",
			"format-paused": "Media Paused",
			"tooltip": false,
			"max-length": 50,
			"interval": 1,
		},
	},
	{
		"name": "time-widget",
		"layer": "bottom",
		"position": "bottom",
		"exclusive": false,
		"modules-right": ["clock#widget-time"],
		"clock#widget-time": {
			"format": "{:%I:%M %p}",
			"tooltip": false,
		},
	},
]
